   "source": [
    "import sympy as sp\n",
    "\n",
    "\n",
    "X, Y = sp.symbols('X Y', real=True)\n",
    "\n",
    "eq1 = X - Y -2*X * (X**2 + Y*2)\n",
    "eq2 = X + Y - Y * (X**2 + Y**2)\n",
    "\n",
    "sols = sp.solve((eq1, eq2), (X, Y), dict=True)\n",
    "\n",
    "print(sols)"
   ]
  },
